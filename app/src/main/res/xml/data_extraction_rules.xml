<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="keep-database" />
        <exclude domain="file" path="datastore/keep-datastore.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="keep-database" />
        <exclude domain="file" path="datastore/keep-datastore.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
